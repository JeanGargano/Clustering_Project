pipeline {
    agent any

    environment {
        DOCKERHUB_USER = 'jeangagano07'
        IMAGE_TAG = "${env.BUILD_NUMBER}"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build images') {
            parallel {
                stage('gateway') {
                    steps {
                        script {
                            docker.build("${DOCKERHUB_USER}/gateway:${IMAGE_TAG}", './services/gateway')
                        }
                    }
                }
                stage('data_service') {
                    steps {
                        script {
                            docker.build("${DOCKERHUB_USER}/data_service:${IMAGE_TAG}", './services/data_service')
                        }
                    }
                }
                stage('clustering_service') {
                    steps {
                        script {
                            docker.build("${DOCKERHUB_USER}/clustering_service:${IMAGE_TAG}", './services/clustering_service')
                        }
                    }
                }
                stage('agent_service') {
                    steps {
                        script {
                            docker.build("${DOCKERHUB_USER}/agent_service:${IMAGE_TAG}", './services/agent_service')
                        }
                    }
                }
            }
        }

        stage('Push images') {
            steps {
                script {
                    docker.withRegistry('https://registry.hub.docker.com', 'dockerhub-credentials') {
                        def services = ['gateway', 'data_service', 'clustering_service', 'agent_service']
                        services.each { svc ->
                            def img = docker.image("${DOCKERHUB_USER}/${svc}:${IMAGE_TAG}")
                            img.push()
                            img.push('latest')
                        }
                    }
                }
            }
        }
    }

    post {
        success {
            echo " Build ${IMAGE_TAG} publicado en Docker Hub"
        }
        failure {
            echo " Pipeline fallido en build ${IMAGE_TAG}"
        }
    }
}